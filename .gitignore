# ============================================================
#  .gitignore — Magister
# ============================================================

# --- Видеофайлы (заливаются на хостинг через Sprut.IO напрямую) ---
*.mp4
*.avi
*.mkv
*.mov
*.webm
*.flv
*.wmv

# --- Другие крупные медиа ---
*.iso
*.dmg

# --- Архивы (часто временные/исходники, не нужны в репозитории) ---
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz

# --- Системные файлы ОС ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# --- Файлы редакторов ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.bak
*.bak
*.bak2
*.bak3
*.bak4
*.bak5
*.tmp

# --- Локальные черновики и ручные бэкапы ---
.dev-notes/backup/

# --- PHP / общие веб-артефакты ---
*.log
error_log
access_log
.htpasswd

# --- Чувствительные данные (на будущее) ---
.env
.env.local
config.local.php
secrets.php

# --- Sprut.IO / cPanel служебное ---
.sprutio
.htaccess.bak
